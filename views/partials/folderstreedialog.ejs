<wa-dialog id="folderstreedialog"  light-dismiss label="Folders" class="dialog-deny-close">
  <wa-button slot="header-actions" appearance="plain" id="ftdcollapse" size="s" title="Collapse all">
    <wa-icon slot="start" name="minimize"></wa-icon>Collapse
  </wa-button>
  <wa-button slot="header-actions" appearance="plain" id="ftdexpand" size="s" title="Expand all">
    <wa-icon slot="start" name="maximize"></wa-icon>Expand
  </wa-button>
  <wa-tree id="generictree">
  </wa-tree>
</wa-dialog>